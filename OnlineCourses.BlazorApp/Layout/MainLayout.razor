@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav

<div class="app-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <div class="main-area">
        <header class="topbar">
            <div class="topbar-left">
                <div class="system-status-widget shadow-sm" @onclick="HandleQuickSearch">
                    <div class="status-indicator">
                        <span class="status-dot pulse"></span>
                        <span class="status-text">System Live</span>
                    </div>
                    <div class="search-trigger">
                        <i class="bi bi-terminal"></i>
                        <span class="shortcut">Press <span>Ctrl K</span> to search</span>
                    </div>
                </div>
            </div>

            <div class="topbar-right">
                @* --- КРАСИВАЯ КНОПКА SETTINGS --- *@
                <div class="topbar-icon-btn settings-btn me-2" @onclick="HandleSettings" title="System Settings">
                    <div class="icon-wrapper">
                        <i class="bi bi-gear-fill"></i>
                    </div>
                </div>

                <div class="topbar-icon-btn notif-btn">
                    <i class="bi bi-bell"></i>
                    <span class="notif-badge">6</span>
                </div>

                <div class="topbar-divider"></div>

                <AuthorizeView>
                    <Authorized>
                        <div class="topbar-user">
                            <div class="user-texts d-none d-md-flex text-end">
                                <span class="user-fullname">@context.User.Identity?.Name</span>
                
                                <span class="user-role-tag">
                                    @if (context.User.IsInRole("Admin")) { <span>Admin Access</span> }
                                    else if (context.User.IsInRole("Instructor")) { <span>Instructor Pro</span> }
                                    else if (context.User.IsInRole("Student")) { <span>Student Portal</span> }
                                    else { <span>User</span> }
                                </span>
                            </div>
            
                            <div class="user-avatar-wrapper shadow-sm ms-3">
                                <div class="user-avatar">
                                    @(context.User.Identity?.Name?[..1].ToUpper() ?? "U")
                                </div>
                            </div>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="page-content">
            @Body
        </main>
    </div>
</div>

@code {
    private void HandleQuickSearch() => Console.WriteLine("Command Palette Triggered");
    private void HandleSettings() => Nav.NavigateTo("/profile/settings");
}