@page "/login"
@layout EmptyLayout
@using OnlineCourses.BlazorApp.Components.Buttons
@using OnlineCourses.BlazorApp.Components.Inputs
@using OnlineCourses.BlazorApp.Models.Auth
@using OnlineCourses.BlazorApp.Services.Auth
@inject AuthService AuthService
@inject NavigationManager Nav
@attribute [AllowAnonymous]  

<div class="auth-container">
    <div class="glass-card">
        <div class="logo-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
        </div>

        <h1>Welcome back</h1>
        <p class="subtitle">Sign in to continue your education</p>

        <EditForm Model="@model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-grid">
                <AppInput Label="Email address" 
                          Placeholder="you@example.com" 
                          @bind-Value="@model.Email" 
                          For="@(() => model.Email)" />

                <AppInput Label="Password" 
                          Type="password" 
                          Placeholder="••••••••" 
                          @bind-Value="@model.Password"
                          For="@(() => model.Password)">
                    <LabelContent>
                        <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                    </LabelContent>
                </AppInput>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="error-banner">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @error
                </div>
            }

            <AppButton Type="submit" IsLoading="loading">
                Sign in 
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </AppButton>
        </EditForm>

        <p class="footer-text">
            Don't have an account? <a href="/register">Create Account</a>
        </p>
    </div>
</div>

@code {
    private LoginRequest model = new();
    private bool loading = false;
    private string? error;

    private async Task HandleLogin() {
        loading = true;
        error = null;
        var result = await AuthService.Login(model);
        if (result.IsSuccess) Nav.NavigateTo("/");
        else error = result.Error;
        loading = false;
    }
}