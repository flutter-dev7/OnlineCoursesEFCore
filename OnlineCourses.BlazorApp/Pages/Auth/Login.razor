@page "/login"
@using OnlineCourses.BlazorApp.Models.Auth
@using OnlineCourses.BlazorApp.Services.Auth
@using OnlineCourses.BlazorApp.Components.Inputs
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Sign In — OnlineCourses</PageTitle>

<div class="lp-root">

    <!-- LEFT -->
    <div class="lp-left">
        <div class="lp-logo">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <polygon points="11,2 20,7 20,15 11,20 2,15 2,7"
                         stroke="#e8c97a" stroke-width="1.4" fill="none"/>
                <circle cx="11" cy="11" r="3" fill="#e8c97a" opacity=".7"/>
            </svg>
            OnlineCourses
        </div>

        <div class="lp-left-body">
            <h2>Learn<br><em>without limits.</em></h2>
            <p>Hundreds of expert-led courses. Learn at your pace, on any device.</p>

            <div class="lp-stats">
                <div class="lp-stat"><strong>12k+</strong><span>Students</span></div>
                <div class="lp-stat"><strong>340+</strong><span>Courses</span></div>
                <div class="lp-stat"><strong>98%</strong><span>Satisfaction</span></div>
            </div>
        </div>

        <div class="lp-dots">
            <span class="lp-dot active"></span>
            <span class="lp-dot"></span>
            <span class="lp-dot"></span>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="lp-right">
        <div class="lp-card">
            <h1>Sign In</h1>
            <p class="lp-sub">Welcome back — let's keep learning.</p>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="lp-error">@error</div>
            }

            <EditForm Model="model" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="lp-field">
                    <label>Email</label>
                    <AppInput @bind-Value="model.Email"
                              Placeholder="you@example.com">
                        <Icon>
                            <svg width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="1.8">
                                <rect x="2" y="4" width="20" height="16" rx="3"/>
                                <path d="M2 7l10 7 10-7"/>
                            </svg>
                        </Icon>
                    </AppInput>
                    <ValidationMessage For="@(() => model.Email)" />
                </div>

                <div class="lp-field">
                    <label>Password</label>
                    <AppInput @bind-Value="model.Password"
                              Type="password"
                              Placeholder="••••••••">
                        <Icon>
                            <svg width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="1.8">
                                <rect x="3" y="11" width="18" height="11" rx="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </Icon>
                    </AppInput>
                    <ValidationMessage For="@(() => model.Password)" />
                </div>

                <div class="lp-row">
                    <label class="lp-remember">
                        <input type="checkbox" @bind="rememberMe" />
                        <span class="lp-check"></span>
                        Remember me
                    </label>
                    <a href="/forgot-password" class="lp-forgot">Forgot password?</a>
                </div>

                <button type="submit" class="lp-btn" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="lp-spinner"></span>
                        <text>Signing in...</text>
                    }
                    else
                    {
                        <text>Sign In</text>
                    }
                </button>
            </EditForm>

            <div class="lp-divider"><span>or</span></div>
            <p class="lp-register">
                New here? <a href="/register">Create an account</a>
            </p>
        </div>
    </div>
</div>

@code {
    LoginRequest model = new();
    string? error;
    bool isLoading;
    bool rememberMe;

    async Task HandleLogin()
    {
        isLoading = true;
        error = null;
        StateHasChanged();

        var result = await AuthService.Login(model);

        if (result.IsSuccess)
            Nav.NavigateTo("/courses");
        else
            error = result.Error ?? "Invalid email or password";

        isLoading = false;
    }
}