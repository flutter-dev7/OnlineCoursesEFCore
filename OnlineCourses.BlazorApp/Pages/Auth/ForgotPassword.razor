@page "/forgot-password"
@layout EmptyLayout
@using OnlineCourses.BlazorApp.Components.Inputs
@using OnlineCourses.BlazorApp.Components.Buttons
@using OnlineCourses.BlazorApp.Models.Auth
@inject OnlineCourses.BlazorApp.Services.Auth.AuthService AuthService
@inject NavigationManager Nav
@attribute [AllowAnonymous]  

<div class="auth-container">
    <div class="glass-card">
        <div class="logo-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3y-2.5-2.5z"/></svg>
        </div>

        @if (currentStep == Step.Email)
        {
            <h1>Reset Password</h1>
            <p class="subtitle">Enter your email to receive a 6-digit verification code.</p>

            <EditForm Model="sendEmailModel" OnValidSubmit="HandleSendEmail">
                <DataAnnotationsValidator />
                <div class="form-grid">
                    <AppInput Label="Email Address" Placeholder="you@example.com" @bind-Value="sendEmailModel.Email" For="@(() => sendEmailModel.Email)" />
                </div>
                <AppButton Type="submit" IsLoading="loading">Send Code</AppButton>
            </EditForm>
        }
        else if (currentStep == Step.Code)
        {
            <h1>Verify Code</h1>
            <p class="subtitle">We've sent a 6-digit code to <strong>@AuthService.GetResetEmail()</strong></p>

            <EditForm Model="verifyCodeModel" OnValidSubmit="HandleVerifyCode">
                <DataAnnotationsValidator />
                <div class="form-grid">
                    <AppInput Label="Verification Code" Placeholder="000000" @bind-Value="verifyCodeModel.Code" For="@(() => verifyCodeModel.Code)" />
                </div>
                <AppButton Type="submit" IsLoading="loading">Verify Code</AppButton>
                <button type="button" class="resend-link" @onclick="HandleSendEmail">Didn't get a code? Resend</button>
            </EditForm>
        }
        else if (currentStep == Step.NewPassword)
        {
            <h1>New Password</h1>
            <p class="subtitle">Create a new secure password for your account.</p>

            <EditForm Model="resetPasswordModel" OnValidSubmit="HandleResetPassword">
                <DataAnnotationsValidator />
                <div class="form-grid">
                    <AppInput Label="New Password" Type="password" Placeholder="••••••••" @bind-Value="resetPasswordModel.NewPassword" For="@(() => resetPasswordModel.NewPassword)" />
                    <AppInput Label="Confirm Password" Type="password" Placeholder="••••••••" @bind-Value="resetPasswordModel.ConfirmPassword" For="@(() => resetPasswordModel.ConfirmPassword)" />
                </div>
                <AppButton Type="submit" IsLoading="loading">Reset Password</AppButton>
            </EditForm>
        }

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="error-banner">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span>@error</span>
            </div>
        }

        <p class="footer-text">
            Remembered your password? <a href="/login">Sign In</a>
        </p>
    </div>
</div>

@code {
    private enum Step { Email, Code, NewPassword }
    private Step currentStep = Step.Email;
    private bool loading = false;
    private string? error;

    private SendEmailRequest sendEmailModel = new();
    private VerifyCodeRequest verifyCodeModel = new();
    private ResetPasswordRequest resetPasswordModel = new();

    private async Task HandleSendEmail()
    {
        loading = true; error = null;
        var result = await AuthService.SendResetCode(sendEmailModel);
        if (result != null && result.IsSuccess) currentStep = Step.Code;
        else error = result?.Error;
        loading = false;
    }

    private async Task HandleVerifyCode()
    {
        loading = true; error = null;
        var result = await AuthService.VerifyCode(verifyCodeModel.Code);
        if (result != null && result.IsSuccess) currentStep = Step.NewPassword;
        else error = result?.Error;
        loading = false;
    }

    private async Task HandleResetPassword()
    {
        loading = true; error = null;
        var result = await AuthService.ResetPassword(resetPasswordModel.NewPassword, resetPasswordModel.ConfirmPassword);
        if (result.IsSuccess) Nav.NavigateTo("/login");
        else error = result.Error;
        loading = false;
    }
}