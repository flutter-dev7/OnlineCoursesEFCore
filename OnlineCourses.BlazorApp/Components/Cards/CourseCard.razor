@using OnlineCourses.BlazorApp.Models.Courses

<div class="course-card-wrapper">
    <div class="course-card @(Course.IsPublished ? "" : "is-draft") animate__animated animate__fadeIn">
        
        @* ПАНЕЛЬ УПРАВЛЕНИЯ (Action Buttons) *@
        <div class="card-actions-column">
            <button class="action-btn lessons" @onclick="() => OnManageLessons.InvokeAsync()" title="Lessons">
                <i class="bi bi-collection-play-fill"></i>
            </button>
            <button class="action-btn publish @(Course.IsPublished ? "active" : "")" 
                    @onclick="() => OnTogglePublish.InvokeAsync(Course)"
                    title="@(Course.IsPublished ? "Unpublish" : "Publish")">
                <i class="bi @(Course.IsPublished ? "bi-eye-fill" : "bi-eye-slash-fill")"></i>
            </button>
            <button class="action-btn edit" @onclick="() => OnEdit.InvokeAsync(Course)" title="Edit">
                <i class="bi bi-pencil-square"></i>
            </button>
            <button class="action-btn delete" @onclick="() => OnDelete.InvokeAsync(Course)" title="Delete">
                <i class="bi bi-trash3-fill"></i>
            </button>
        </div>

        <div class="card-body">
            @* БЕЙДЖИ УРОВНЯ *@
            <div class="badge-row">
                <span class="badge-tag level-@Course.Level.ToString().ToLower()">@Course.Level</span>
                @if (!Course.IsPublished)
                {
                    <span class="badge-tag draft-tag">Draft</span>
                }
            </div>

            @* ЗАГОЛОВОК КУРСА *@
            <h4 class="course-title">@Course.Title</h4>
            
            @* ОПИСАНИЕ КУРСА *@
            <p class="course-description">
                @(string.IsNullOrWhiteSpace(Course.Description) ? "No description provided." : Course.Description)
            </p>

            @* БЛОК ИНСТРУКТОРА (Всегда на одной линии) *@
            <div class="instructor-row">
                <div class="avatar-box">@Course.InstructorName[0]</div>
                <div class="instructor-text">
                    <span class="label">Instructor</span>
                    <span class="name">@Course.InstructorName</span>
                </div>
            </div>

            @* Распорка для прижимания футера *@
            <div class="flex-spacer"></div>
        </div>

        @* НИЖНЯЯ ПАНЕЛЬ (Цена и Статистика) *@
        <div class="card-footer-premium">
            <div class="price-box">
                <span class="curr">$</span>
                <span class="val">@Course.Price</span>
            </div>
            <div class="stats-box">
                <div class="stat-pill">
                    <i class="bi bi-play-circle-fill"></i>
                    <span>@Course.LessonCount</span>
                </div>
                <div class="stat-pill rating">
                    <i class="bi bi-star-fill"></i>
                    <span>@Course.AverageRating.ToString("F1")</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public CourseResponse Course { get; set; } = null!;
    [Parameter] public EventCallback<CourseResponse> OnEdit { get; set; }
    [Parameter] public EventCallback<CourseResponse> OnDelete { get; set; }
    [Parameter] public EventCallback<CourseResponse> OnTogglePublish { get; set; }
    [Parameter] public EventCallback OnManageLessons { get; set; }
}