@using OnlineCourses.BlazorApp.Models.Courses

<div class="course-slim-card shadow-sm">
    @* Верхняя часть с градиентом *@
    <div class="card-visual-sm" style="background: @GetGradient()">
        <span class="badge-mini">@Course.CategoryName</span>
        <div class="level-tag">@Course.Level</div>
        <i class="bi @GetIcon() floating-icon-sm"></i>
    </div>

    <div class="card-body p-3 d-flex flex-column">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="instructor-tag">
                <i class="bi bi-person-circle me-1"></i>@Course.InstructorName
            </span>
            <div class="rating-mini">
                <i class="bi bi-star-fill text-warning"></i> @Course.AverageRating.ToString("F1")
            </div>
        </div>

        <h6 class="course-title-slim" title="@Course.Title">@Course.Title</h6>
        <p class="course-desc-slim">@Course.Description</p>

        <div class="course-info-row d-flex justify-content-between">
            <span><i class="bi bi-book me-1"></i> @Course.LessonCount Lessons</span>
            <span><i class="bi bi-clock me-1"></i> Self-paced</span>
        </div>

        <div class="card-footer-slim mt-auto pt-2">
            <div class="price-sm mb-2">
                @if (Course.Price > 0)
                {
                    <span>$@Course.Price.ToString("N0")</span>
                }
                else
                {
                    <span class="text-success fw-bold">FREE</span>
                }
            </div>

            @if (IsEnrolled)
            {
                <button class="btn btn-go-learning w-100" @onclick="OnView">
                    <i class="bi bi-check2-circle me-1"></i> My Courses
                </button>
            }
            else
            {
                <button class="btn btn-enroll-slim w-100" @onclick="OnEnroll" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    else
                    {
                        <span>Enroll Now</span>
                        <i class="bi bi-lightning-fill ms-1"></i>
                    }
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public CourseResponse Course { get; set; } = default!;
    [Parameter] public bool IsEnrolled { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback OnEnroll { get; set; }
    [Parameter] public EventCallback OnView { get; set; }

    // Рандомные иконки для красоты, если нет Thumbnail
    private string GetIcon() => Course.CategoryName.ToLower() switch {
        "backend" => "bi-database-fill",
        "frontend" => "bi-braces",
        "mobile" => "bi-phone-fill",
        _ => "bi-rocket-takeoff"
    };

    private string GetGradient() => Course.CategoryName.ToLower() switch {
        "backend" => "linear-gradient(135deg, #1e293b 0%, #334155 100%)",
        "frontend" => "linear-gradient(135deg, #5932EA 0%, #7d5fff 100%)",
        _ => "linear-gradient(135deg, #6366f1 0%, #a855f7 100%)"
    };
}