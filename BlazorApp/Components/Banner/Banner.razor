<div class="banner-container">
    <button class="banner-arrow left" @onclick="Prev">&#8249;</button>

    <div class="banner-content">
        <span class="banner-text">@Slides[CurrentIndex]</span>
    </div>

    <button class="banner-arrow right" @onclick="Next">&#8250;</button>
</div>

@code {
    [Parameter] public List<string> Slides { get; set; } = new() 
    { 
        "Baner 1", 
        "Baner 2", 
        "Baner 3" 
    };

    private int CurrentIndex = 0;

    private void Prev()
    {
        CurrentIndex = (CurrentIndex - 1 + Slides.Count) % Slides.Count;
    }

    private void Next()
    {
        CurrentIndex = (CurrentIndex + 1) % Slides.Count;
    }
}