<header class="main-header">
    @* Левая часть: Логотип *@
    <div class="header-left">
        <div class="logo-box">
            <div class="logo-text-top">SOFT</div>
            <div class="logo-text-bottom">CLUB</div>
        </div>
    </div>

    @* Центральная часть: Название компонента *@
    <div class="header-center">
        <h1 class="header-title">Header</h1>
    </div>

    @* Правая часть: Наш новый компонент кнопки *@
    <div class="header-right">
        <OrangeButton OnClick="HandleSignIn">
            Sign in
        </OrangeButton>
    </div>
</header>

@code {
private void HandleSignIn()
{
// Логика при нажатии (например, переход на страницу логина)
Console.WriteLine("Кнопка Sign In нажата!");
}
}

<style>
