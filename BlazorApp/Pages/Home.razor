@page "/"
@using BlazorApp.Components.Aside
@using BlazorApp.Components.Header
@using BlazorApp.Components.Banner
@using BlazorApp.Components.Card
@using BlazorApp.Components.Footer

<div style="display: flex; flex-direction: column; height: 100%; overflow: hidden; box-sizing: border-box; padding: 16px; gap: 16px;">

    <div style="display: flex; flex-grow: 1; overflow: hidden; gap: 16px;">

        <AsideMenu />

        <div style="flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; gap: 16px;">

            <Header></Header>

            <div style="flex-grow: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 16px;">

                <Banner />

                <div style="display: flex; gap: 12px; align-items: stretch;">
                    <Card Title="Card" />
                    <Card Title="Card" />
                    <Card Title="Card" />
                    <Card Title="Card" />
                    <Card Title="Card" />
                </div>

            </div>

        </div>
    </div>

    <div style="display: flex; flex-grow: 1; max-height: 120px;">
        <Footer></Footer>
    </div>
</div>


