@model ErrorViewModel
@{
    ViewData["Title"] = "System Error";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 5rem;"></i>
            </div>

            <h1 class="display-4 fw-bold text-dark">Oops! Something went wrong</h1>
            <p class="lead text-muted mb-4">
                We encountered an unexpected error while processing your request. 
                Don't worry, our team has been notified.
            </p>

            <div class="d-flex justify-content-center gap-3 mb-5">
                <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 rounded-pill">
                    <i class="bi bi-arrow-left me-2"></i>Go Back
                </a>
                <a href="/" class="btn btn-primary px-4 rounded-pill" style="background: #5932EA; border: none;">
                    <i class="bi bi-house-door me-2"></i>Home Page
                </a>
            </div>

            <div class="card border-0 shadow-sm text-start" style="border-radius: 20px; background: #f8f9fa;">
                <div class="card-body p-4">
                    <button class="btn btn-link text-decoration-none text-dark fw-bold p-0 mb-2 w-100 text-start d-flex justify-content-between" 
                            type="button" data-bs-toggle="collapse" data-bs-target="#errorDetails">
                        Technical Details (Infrastructure)
                        <i class="bi bi-chevron-down"></i>
                    </button>

                    <div class="collapse" id="errorDetails">
                        <hr>
                        <div class="small">
                            @if (Model.ShowRequestId)
                            {
                                <p class="mb-1"><strong>Request ID:</strong> <span class="badge bg-dark text-white">@Model.RequestId</span></p>
                            }
                            
                            <p class="mb-1"><strong>Timestamp:</strong> @DateTime.Now.ToString("G")</p>
                            
                            @if (Context.Items["ExceptionMessage"] != null)
                            {
                                <p class="mb-1 text-danger"><strong>Exception:</strong> @Context.Items["ExceptionMessage"]</p>
                            }

                            <div class="mt-3 p-3 bg-white border rounded" style="max-height: 200px; overflow-y: auto;">
                                <p class="extra-small text-muted mb-0">
                                    <strong>Path:</strong> @Context.Request.Path <br>
                                    <strong>Method:</strong> @Context.Request.Method
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #FAFBFF; }
    .extra-small { font-size: 11px; font-family: 'Courier New', Courier, monospace; }
</style>