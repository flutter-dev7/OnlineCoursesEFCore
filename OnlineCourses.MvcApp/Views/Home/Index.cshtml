@{
    ViewData["Title"] = "Home";
    var userName = ViewBag.UserName ?? "Student";
}

<div class="container-fluid p-0" style="background: #F8F9FD; min-height: 100vh;">
    
    @* --- ГЛАВНЫЙ ГЕРОЙ-БЛОК (HERO SECTION) --- *@
    <div class="hero-section p-5 mb-5">
        <div class="container">
            <div class="row align-items-center py-5">
                <div class="col-lg-7">
                    <span class="badge rounded-pill bg-primary px-3 py-2 mb-4 shadow-sm fw-bold" style="background: rgba(89, 50, 234, 0.1) !important; color: #5932EA;">
                        <i class="bi bi-stars me-1"></i> PERSONAL DASHBOARD
                    </span>
                    <h1 class="display-3 fw-bold mb-3" style="color: #1A202C;">
                        Great to see you, <span style="color: #5932EA;">@userName!</span>
                    </h1>
                    <p class="fs-5 text-muted mb-5 w-75">
                        Your journey to excellence continues here. Ready to master new skills and push your boundaries today?
                    </p>
                    
                    <div class="d-flex gap-3">
                        <a asp-controller="Courses" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-lg fw-bold" style="background: #5932EA; border: none;">
                            Find New Courses
                        </a>
                        <a asp-controller="Enrollments" asp-action="MyLearning" class="btn btn-outline-dark btn-lg rounded-pill px-5 py-3 fw-bold">
                            My Learning
                        </a>
                    </div>
                </div>
                
                <div class="col-lg-5 d-none d-lg-block">
                    <div class="illustration-box">
                        <img src="https://img.freepik.com/free-vector/learning-concept-illustration_114360-6186.jpg" class="img-fluid floating-img" alt="Learning">
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- ВИДЖЕТЫ / БЫСТРЫЕ ССЫЛКИ --- *@
    <div class="container pb-5">
        <div class="row g-4">
            @* Карточка 1 *@
            <div class="col-md-4">
                <div class="action-card p-4 h-100 shadow-sm border-0">
                    <div class="icon-circle mb-4" style="background: #EBF4FF; color: #3182CE;">
                        <i class="bi bi-lightning-fill"></i>
                    </div>
                    <h4 class="fw-bold">Fast Track</h4>
                    <p class="text-muted small">Jump straight back into your last accessed lesson and keep the flow.</p>
                    <a asp-controller="Enrollments" asp-action="MyLearning" class="text-decoration-none fw-bold" style="color: #3182CE;">Resume Now <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>

            @* Карточка 2 *@
            <div class="col-md-4">
                <div class="action-card p-4 h-100 shadow-sm border-0">
                    <div class="icon-circle mb-4" style="background: #F0FFF4; color: #38A169;">
                        <i class="bi bi-trophy-fill"></i>
                    </div>
                    <h4 class="fw-bold">My Achievements</h4>
                    <p class="text-muted small">View your earned certificates and track your professional growth.</p>
                    <a href="#" class="text-decoration-none fw-bold" style="color: #38A169;">View Badges <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>

            @* Карточка 3 *@
            <div class="col-md-4">
                <div class="action-card p-4 h-100 shadow-sm border-0">
                    <div class="icon-circle mb-4" style="background: #FFF5F5; color: #E53E3E;">
                        <i class="bi bi-gear-fill"></i>
                    </div>
                    <h4 class="fw-bold">Settings</h4>
                    <p class="text-muted small">Update your profile, change your goals, or manage your notifications.</p>
                    <a href="#" class="text-decoration-none fw-bold" style="color: #E53E3E;">Account Settings <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Анимация парения для картинки */
    .floating-img {
        animation: floating 3s ease-in-out infinite;
    }

    @@keyframes floating {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
        100% { transform: translateY(0px); }
    }

    .hero-section {
        background: #ffffff;
        border-bottom: 1px solid #edf2f7;
    }

    .action-card {
        background: #ffffff;
        border-radius: 30px;
        transition: all 0.3s ease;
        border: 1px solid #f1f1f1 !important;
    }

    .action-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.05) !important;
        border-color: #5932EA !important;
    }

    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .fw-bold { font-weight: 700 !important; }
</style>