@model CourseIndexViewModel
@{
    ViewData["Title"] = "Courses";
    var isStudent = Context.Request.Cookies["user_role"] == "Student";
    var userName = Context.Request.Cookies["user_name"] ?? "User";
}

@* --- NOTIFICATIONS --- *@
<div id="alert-container" class="position-fixed top-0 end-0 p-3" style="z-index: 1060;">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm auto-close" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 shadow-sm auto-close" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            @if (isStudent)
            {
                <h2 class="fw-bold m-0" style="color: #292D32;">Choose your path, @userName 🚀</h2>
                <p class="text-muted small">Invest in your knowledge today.</p>
            }
            else
            {
                <h3 class="fw-bold m-0" style="color: #000;">Course Management</h3>
                <p class="text-muted small">Create and manage your educational content</p>
            }
        </div>

        @if (!isStudent)
        {
            <button type="button" class="btn btn-primary px-4 py-2 d-inline-flex align-items-center shadow-sm create-btn"
                    data-bs-toggle="modal" data-bs-target="#createCourseModal">
                <i class="bi bi-plus-lg me-2"></i> Add New Course
            </button>
        }
    </div>

    @if (isStudent)
    {
        <div class="row g-4">
            @foreach (var course in Model.Courses.Where(c => c.IsPublished))
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border-0 student-course-card">
                        <div class="card-header-visual">
                            <div class="course-category-tag">@course.CategoryName</div>
                            <div class="visual-icon">
                                <i class="bi bi-code-square display-4 text-white opacity-25"></i>
                            </div>
                        </div>

                        <div class="card-body p-4 d-flex flex-column">
                            <h5 class="fw-bold text-dark mb-2 lh-base">@course.Title</h5>

                            <div class="d-flex align-items-center mb-3">
                                <img src="https://ui-avatars.com/api/?name=@course.InstructorName&background=random"
                                     class="rounded-circle me-2" width="24" alt="@course.InstructorName">
                                <span class="text-muted small">@course.InstructorName</span>
                            </div>

                            <p class="text-muted small text-truncate-2 mb-4">
                                @(string.IsNullOrEmpty(course.Description)
                                    ? "Master in-demand skills from scratch with guidance from industry experts."
                                    : course.Description)
                            </p>

                            <div class="mt-auto d-flex justify-content-between align-items-center pt-3 border-top">
                                <div>
                                    <span class="text-muted d-block" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px;">Price</span>
                                    <span class="fw-bold fs-5 text-dark">@(course.Price == 0 ? "Free" : $"${course.Price}")</span>
                                </div>

                                @if (course.IsEnrolled)
                                {
                                    <div class="d-flex align-items-center text-success fw-bold" style="font-size: 13px;">
                                        <i class="bi bi-patch-check-fill me-1"></i> Enrolled
                                    </div>
                                }
                                else
                                {
                                    <form asp-controller="Enrollments" asp-action="Enroll" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="courseId" value="@course.Id" />
                                        <button type="submit"
                                                class="btn btn-primary px-3 rounded-pill fw-bold shadow-sm"
                                                style="background: #5932EA; border: none; font-size: 13px;">
                                            Enroll Now <i class="bi bi-plus-lg ms-1"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm" style="border-radius: 25px;">
            <div class="card-body p-4">
                <div class="table-responsive" style="overflow: visible !important;">
                    <table class="table align-middle custom-table">
                        <thead>
                            <tr class="small text-muted">
                                <th class="ps-3 border-0 fw-bold">COURSE NAME</th>
                                <th class="border-0 fw-bold">INSTRUCTOR</th>
                                <th class="border-0 fw-bold">CATEGORY</th>
                                <th class="border-0 fw-bold">PRICE</th>
                                <th class="border-0 fw-bold">STATUS</th>
                                <th class="text-end pe-4 border-0 fw-bold">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var course in Model.Courses)
                            {
                                <tr>
                                    <td class="ps-3 py-3">
                                        <div class="fw-bold text-dark" style="font-size: 15px;">@course.Title</div>
                                        <div class="text-muted" style="font-size: 11px;">ID: @course.Id.ToString().Substring(0, 8)...</div>
                                    </td>
                                    <td class="fw-medium text-secondary">@course.InstructorName</td>
                                    <td><span class="badge bg-light text-dark rounded-pill px-3 py-2 fw-bold">@course.CategoryName</span></td>
                                    <td class="fw-bold text-dark">$@course.Price</td>
                                    <td>
                                        @if (course.IsPublished)
                                        {
                                            <span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning px-3 py-2">Draft</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="dropdown">
                                            <i class="bi bi-three-dots-vertical cursor-pointer fs-5" data-bs-toggle="dropdown"></i>
                                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg" style="border-radius: 15px;">
                                                <li>
    <a class="dropdown-item fw-medium" 
       asp-controller="Lessons" asp-action="Details" 
       asp-route-courseId="@course.Id">
        <i class="bi bi-play-btn me-2 text-success"></i> View Lessons
    </a>
</li>
                                                <li>
                                                    @*
                                                        КЛЮЧЕВОЙ ФИХ: ищем Guid категории в Model.Categories
                                                        по имени (Text == CategoryName) прямо в Razor на сервере.
                                                        JS просто берёт готовый Guid и ставит его в select.
                                                    *@
                                                    <a class="dropdown-item fw-medium edit-course-btn" href="#"
                                                       data-id="@course.Id"
                                                       data-title="@course.Title"
                                                       data-price="@course.Price"
                                                       data-desc="@course.Description"
                                                       data-catid="@Model.Categories.FirstOrDefault(c => c.Text == course.CategoryName)?.Value"
                                                       data-published="@course.IsPublished.ToString().ToLower()">
                                                        <i class="bi bi-pencil-square me-2 text-primary"></i> Edit
                                                    </a>
                                                </li>
                                                <li>
                                                    <form asp-action="TogglePublish" method="post">
                                                        <input type="hidden" name="id" value="@course.Id" />
                                                        <button type="submit" class="dropdown-item fw-medium">
                                                            @if (course.IsPublished)
                                                            {
                                                                <span class="text-warning"><i class="bi bi-eye-slash me-2"></i> Unpublish</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-success"><i class="bi bi-eye me-2"></i> Publish</span>
                                                            }
                                                        </button>
                                                    </form>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item text-danger fw-medium delete-course-btn" href="#"
                                                       data-id="@course.Id" data-title="@course.Title">
                                                        <i class="bi bi-trash3 me-2"></i> Delete
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@* --- MODALS (ADMIN ONLY) --- *@
@if (!isStudent)
{
    <div class="modal fade" id="createCourseModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
                <div class="modal-header border-0 px-4 pt-4">
                    <h5 class="modal-title fw-bold">Add New Course</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="Create" method="post">
                    <div class="modal-body px-4">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">TITLE</label>
                            <input name="Title" class="form-control custom-input" placeholder="e.g. ASP.NET Fundamentals" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">DESCRIPTION</label>
                            <textarea name="Description" class="form-control custom-input" rows="3" placeholder="Briefly describe the course..."></textarea>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">CATEGORY</label>
                                <select name="CategoryId" class="form-select custom-input" asp-items="Model.Categories" required>
                                    <option value="">Select</option>
                                </select>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold text-muted">PRICE ($)</label>
                                <input name="Price" type="number" step="0.01" class="form-control custom-input" placeholder="0.00" required />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4" style="background: #5932EA; border: none;">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editCourseModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
                <div class="modal-header border-0 px-4 pt-4">
                    <h5 class="modal-title fw-bold">Edit Course</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="Id" id="edit-course-id" />
                    <div class="modal-body px-4">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">TITLE</label>
                            <input name="Title" id="edit-course-title" class="form-control custom-input" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">DESCRIPTION</label>
                            <textarea name="Description" id="edit-course-desc" class="form-control custom-input" rows="3"></textarea>
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted">CATEGORY</label>
                                <select name="CategoryId" id="edit-course-cat" class="form-select custom-input" asp-items="Model.Categories" required></select>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted">PRICE ($)</label>
                                <input name="Price" id="edit-course-price" type="number" step="0.01" class="form-control custom-input" required />
                            </div>
                        </div>
                        <div class="form-check form-switch ms-1">
                            <input class="form-check-input" type="checkbox" name="IsPublished" value="true" id="edit-course-published">
                            <label class="form-check-label small fw-bold text-muted" for="edit-course-published">Is Published</label>
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4" style="background: #5932EA; border: none;">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteCourseModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-trash-fill text-danger mb-3" style="font-size: 3rem;"></i>
                    <h5 class="fw-bold">Delete Course?</h5>
                    <p class="text-muted small">Are you sure you want to delete <br><span id="del-title" class="fw-bold text-dark"></span>?</p>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" id="del-id" />
                        <div class="d-flex gap-2 justify-content-center mt-3">
                            <button type="button" class="btn btn-light rounded-pill px-3" data-bs-dismiss="modal">No</button>
                            <button type="submit" class="btn btn-danger rounded-pill px-3 shadow-sm">Yes, Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .cursor-pointer { cursor: pointer; }

    .student-course-card {
        border-radius: 28px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        overflow: hidden;
    }
    .student-course-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(89, 50, 234, 0.12);
    }
    .card-header-visual {
        height: 120px;
        background: linear-gradient(135deg, #5932EA 0%, #7B52FF 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }
    .course-category-tag {
        position: absolute;
        top: 15px;
        left: 15px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(8px);
        color: white;
        padding: 4px 12px;
        border-radius: 10px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .btn-learn-more {
        background: #F0EDFF;
        color: #5932EA;
        border-radius: 12px;
        font-weight: 700;
        font-size: 13px;
        border: none;
        transition: 0.3s;
    }
    .btn-learn-more:hover { background: #5932EA !important; color: white !important; }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .create-btn { background: #5932EA; border-radius: 12px; border: none; font-weight: 600; transition: 0.3s; color: white; }
    .create-btn:hover { background: #4726c2; transform: scale(1.02); color: white; }
    .custom-table thead th { letter-spacing: 0.5px; font-size: 11px; padding-bottom: 15px; }
    .custom-table tbody td { border-bottom: 1px solid #f8f9fa; }

    .custom-input {
        background-color: #f8f9fa !important;
        border: 2px solid #f1f3f5 !important;
        border-radius: 14px !important;
        padding: 12px 15px !important;
        transition: 0.2s;
    }
    .custom-input:focus {
        border-color: #5932EA !important;
        box-shadow: 0 0 0 4px rgba(89, 50, 234, 0.1) !important;
        background-color: #fff !important;
    }
</style>

    <script>
        $(document).ready(function () {

            setTimeout(function () {
                $('.auto-close').fadeOut('slow');
            }, 4000);

            $('.edit-course-btn').on('click', function (e) {
                e.preventDefault();
                const btn = $(this);
                $('#edit-course-id').val(btn.data('id'));
                $('#edit-course-title').val(btn.data('title'));
                $('#edit-course-desc').val(btn.data('desc'));
                $('#edit-course-price').val(btn.data('price').toString().replace(',', '.'));

                // data-catid уже содержит готовый Guid (Razor нашёл его по имени категории)
                $('#edit-course-cat').val(btn.data('catid'));

                const isPublished = btn.data('published');
                $('#edit-course-published').prop('checked', isPublished === true || isPublished === "true");
                $('#editCourseModal').modal('show');
            });

            $('.delete-course-btn').on('click', function (e) {
                e.preventDefault();
                $('#del-id').val($(this).data('id'));
                $('#del-title').text($(this).data('title'));
                $('#deleteCourseModal').modal('show');
            });
        });
    </script>

