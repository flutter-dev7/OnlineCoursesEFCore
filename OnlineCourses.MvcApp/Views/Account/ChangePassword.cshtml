@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<style>
    .auth-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        background: white;
        padding: 45px;
        border-radius: 30px;
        box-shadow: 0 10px 60px rgba(226, 236, 249, 0.5);
        width: 100%;
        max-width: 420px;
    }

    .logo-area {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 30px;
    }

    .logo-area i {
        font-size: 30px;
        color: #5932EA;
    }

    .logo-area span {
        font-size: 22px;
        font-weight: 600;
        color: #292D32;
    }

    .form-label {
        font-size: 13px;
        font-weight: 500;
        color: #292D32;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 15px;
        background: #F9FBFF;
        border: 1px solid #F0F0F0;
        font-size: 14px;
    }

    .form-control:focus {
        box-shadow: 0 0 0 3px rgba(89, 50, 234, 0.1);
        border-color: #5932EA;
    }

    .btn-auth {
        background: #5932EA;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 600;
        transition: 0.3s;
        margin-top: 10px;
    }

    .btn-auth:hover {
        background: #4a29c4;
        transform: translateY(-2px);
        color: white;
    }

    .input-validation-error {
        border-color: #ffa8a8 !important;
        background-color: #fffafb !important;
    }

    .input-validation-error:focus {
        box-shadow: 0 0 0 3px rgba(224, 49, 49, 0.1) !important;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="logo-area">
            <i class="bi bi-hexagon-fill"></i>
            <span>OnlineCourses</span>
        </div>

        <h4 class="text-center fw-bold mb-1">Change Password</h4>
        <p class="text-center text-muted small mb-4">Update your account password</p>

        <form asp-action="ChangePassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label"></label>
                <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmNewPassword" class="form-label"></label>
                <input asp-for="ConfirmNewPassword" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-auth w-100">
                Update Password
            </button>
        </form>

    </div>
</div>