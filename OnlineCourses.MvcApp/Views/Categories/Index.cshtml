@model List<CategoryViewModel>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold m-0" style="color: #000;">Course Categories</h3>
            <p class="text-muted small">Manage and organize your course topics</p>
        </div>
        <button type="button" class="btn btn-primary px-4 py-2 d-inline-flex align-items-center shadow-sm" 
                style="background: #5932EA; border-radius: 12px; border: none; font-weight: 600;"
                data-bs-toggle="modal" data-bs-target="#createCategoryModal">
            <i class="bi bi-plus-lg me-2"></i> Add New Category
        </button>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 25px;">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table align-middle custom-table">
                    <thead>
                        <tr class="small">
                            <th class="ps-3 border-0 fw-bold" style="color: #000; padding-bottom: 10px;">Category Name</th>
                            <th class="border-0 fw-bold" style="color: #000; padding-bottom: 10px;">Description</th>
                            <th class="text-end pe-4 border-0 fw-bold" style="color: #000; padding-bottom: 10px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold" style="font-size: 15px; color: #000;">@cat.Name</div>
                                    <div class="text-muted extra-small">ID: @cat.Id.ToString().Substring(0, 8)...</div>
                                </td>
                                <td>
                                    <span class="fw-medium" style="color: #2D2E2E;">
                                        @(string.IsNullOrEmpty(cat.Description) ? "No description provided" : cat.Description)
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <i class="bi bi-three-dots-vertical cursor-pointer" data-bs-toggle="dropdown" style="font-size: 18px; color: #000;"></i>
                                        <ul class="dropdown-menu border-0 shadow-lg" style="border-radius: 12px;">
                                            <li>
                                                <a class="dropdown-item fw-medium edit-btn" href="#" 
                                                   data-id="@cat.Id" 
                                                   data-name="@cat.Name" 
                                                   data-desc="@cat.Description">
                                                   <i class="bi bi-pencil me-2"></i> Edit
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <a class="dropdown-item text-danger fw-medium delete-btn" href="#" 
                                                   data-id="@cat.Id" 
                                                   data-name="@cat.Name">
                                                   <i class="bi bi-trash me-2"></i> Delete
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
            <div class="modal-header border-0 px-4 pt-4">
                <h5 class="modal-title fw-bold" style="font-size: 1.25rem; color: #000;">New Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body px-4">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted ms-1">CATEGORY NAME</label>
                        <input name="Name" class="form-control custom-input" placeholder="e.g. Backend Development" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted ms-1">DESCRIPTION</label>
                        <textarea name="Description" class="form-control custom-input" rows="3" placeholder="Briefly describe this category..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold" data-bs-dismiss="modal" style="color: #666;">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm" style="background: #5932EA; border: none;">Create Category</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
            <div class="modal-header border-0 px-4 pt-4">
                <h5 class="modal-title fw-bold" style="font-size: 1.25rem; color: #000;">Edit Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Edit" method="post">
                <input type="hidden" name="Id" id="edit-id" />
                <div class="modal-body px-4">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted ms-1">CATEGORY NAME</label>
                        <input name="Name" id="edit-name" class="form-control custom-input" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-bold text-muted ms-1">DESCRIPTION</label>
                        <textarea name="Description" id="edit-desc" class="form-control custom-input" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold" data-bs-dismiss="modal" style="color: #666;">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm" style="background: #5932EA; border: none;">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
            <div class="modal-body p-4 text-center">
                <div class="mb-3">
                    <i class="bi bi-exclamation-circle text-danger" style="font-size: 3.5rem;"></i>
                </div>
                <h5 class="fw-bold text-dark">Are you sure?</h5>
                <p class="text-muted small">You want to delete <span id="delete-category-name" class="fw-bold text-dark"></span>? This action is permanent.</p>
                
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" id="delete-id" />
                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger rounded-pill px-4 fw-semibold shadow-sm">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Таблица: Стиль как на скриншотах */
    .custom-table tbody td { 
        padding: 12px 0; 
        border-bottom: 1px solid #F1F1F1;
    }
    .custom-table thead th { text-transform: none !important; }
    .custom-table tbody tr:last-child td { border-bottom: none; }
    .extra-small { font-size: 11px; color: #B5B7C0; margin-top: 2px; }
    .cursor-pointer { cursor: pointer; transition: 0.2s; }
    .cursor-pointer:hover { opacity: 0.7; }
    .custom-table tbody tr:hover { background-color: #F9FBFF; }

    /* Поля ввода (Inputs) */
    .custom-input {
        background-color: #F8F9FA !important;
        border: 2px solid #F8F9FA !important;
        border-radius: 12px !important;
        padding: 12px 16px !important;
        font-size: 14px !important;
        transition: all 0.2s ease-in-out !important;
        color: #000 !important;
        font-weight: 500 !important;
    }
    .custom-input:focus {
        background-color: #fff !important;
        border-color: #5932EA !important;
        box-shadow: 0 0 0 4px rgba(89, 50, 234, 0.1) !important;
        outline: none !important;
    }

    /* Плавность модалок */
    .modal.fade .modal-dialog { transform: scale(0.9); transition: transform 0.2s ease-out; }
    .modal.show .modal-dialog { transform: scale(1); }
</style>

    <script>
        $(document).ready(function() {
            // Передача данных в модалку EDIT
            $('.edit-btn').on('click', function(e) {
                e.preventDefault();
                const id = $(this).data('id');
                const name = $(this).data('name');
                const desc = $(this).data('desc');

                $('#edit-id').val(id);
                $('#edit-name').val(name);
                $('#edit-desc').val(desc);
                $('#editCategoryModal').modal('show');
            });

            // Передача данных в модалку DELETE
            $('.delete-btn').on('click', function(e) {
                e.preventDefault();
                const id = $(this).data('id');
                const name = $(this).data('name');

                $('#delete-id').val(id);
                $('#delete-category-name').text(name);
                $('#deleteCategoryModal').modal('show');
            });
        });
    </script>
